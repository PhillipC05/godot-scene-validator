[gd_scene load_steps=2 format=3]

[ext_resource type="Script" path="res://addons/scene_validator/validator_panel.gd" id="1"]

[node name="ValidatorPanel" type="VBoxContainer"]
script = ExtResource("1")

[node name="Toolbar" type="HBoxContainer" parent="."]
layout_mode = 2

[node name="ValidateButton" type="Button" parent="Toolbar"]
unique_name_in_owner = true
layout_mode = 2
text = "Validate Scene"

[node name="RunOnSaveCheck" type="CheckBox" parent="Toolbar"]
unique_name_in_owner = true
layout_mode = 2
text = "Run on Scene Save"

[node name="StatusLabel" type="Label" parent="."]
unique_name_in_owner = true
layout_mode = 2
text = "Click \"Validate Scene\" to scan the open scene."

[node name="ResultsTree" type="Tree" parent="."]
unique_name_in_owner = true
custom_minimum_size = Vector2(0, 220)
layout_mode = 2
size_flags_vertical = 3
columns = 3
column_titles_visible = true
